# Public app URL — used for email-confirmation redirects.
# In dev: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase ----------------------------------------------------------------
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string for Drizzle.
# Use the Supabase Connection Pooler (Transaction mode, port 6543) for app traffic,
# and the direct connection (port 5432) for drizzle-kit migrations.
DATABASE_URL=

# --- Vertex AI (Slice 4+) ----------------------------------------------------
# GCP project + region for Vertex.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=australia-southeast1
# Path to a service account JSON with Vertex AI User role.
GOOGLE_APPLICATION_CREDENTIALS=./.vertex-key.json

# --- Basiq (Slice 3+) --------------------------------------------------------
BASIQ_API_KEY=
BASIQ_API_URL=https://au-api.basiq.io

# --- Vercel Cron (Slice 3+) --------------------------------------------------
# Random shared secret. Cron handlers verify this against the Authorization header.
CRON_SECRET=
