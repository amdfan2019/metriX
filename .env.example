# Public app URL — used for email-confirmation redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase ----------------------------------------------------------------
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string for Drizzle.
# Use the Supabase Connection Pooler (Transaction mode, port 6543) for app
# traffic, and the direct connection (port 5432) for drizzle-kit migrations.
DATABASE_URL=

# --- Gemini ------------------------------------------------------------------
# Google AI Studio API key (https://aistudio.google.com/apikey).
GEMINI_API_KEY=

# --- Basiq -------------------------------------------------------------------
BASIQ_API_KEY=
BASIQ_API_URL=https://au-api.basiq.io

# --- Vercel Cron -------------------------------------------------------------
# Random shared secret. Cron handlers verify this against the Authorization header.
# Generate with: openssl rand -hex 32
CRON_SECRET=
